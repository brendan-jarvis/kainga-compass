# Copy to .env and fill in real values.
# Schema: src/env.js

# -----------------------------------------------------------------------------
# Supabase (Postgres)
# -----------------------------------------------------------------------------
# App runtime (Vercel/serverless): use Transaction pooler (port 6543)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres"

# Drizzle migrations (db:push, db:migrate): use Direct connection (port 5432)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# NextAuth.js
# -----------------------------------------------------------------------------
# Generate: bunx auth secret
AUTH_SECRET=""

# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app
AUTH_URL="http://localhost:3000"

# GitHub OAuth — https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Skip env validation during Docker/CI builds
# SKIP_ENV_VALIDATION=1
