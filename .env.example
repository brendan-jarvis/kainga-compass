# Copy to .env and fill in real values.
# Schema: src/env.js
#
# Vercel + Supabase integration auto-injects POSTGRES_* vars — DATABASE_URL is
# resolved from those at runtime (no manual mapping needed on Vercel).

# -----------------------------------------------------------------------------
# Supabase (Postgres) — Vercel integration provides these automatically
# -----------------------------------------------------------------------------
# POSTGRES_URL              # Transaction pooler (app runtime) — preferred
# POSTGRES_PRISMA_URL       # Alternative pooler URL
# POSTGRES_URL_NON_POOLING  # Direct connection (migrations / db:push)

# Optional explicit overrides (local dev or non-Vercel hosts):
# DATABASE_URL="postgresql://..."
# DIRECT_URL="postgresql://..."

# -----------------------------------------------------------------------------
# NextAuth.js
# -----------------------------------------------------------------------------
# Generate: bunx auth secret
AUTH_SECRET=""

# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app
AUTH_URL="http://localhost:3000"

# GitHub OAuth — https://github.com/settings/developers
# Callback: {AUTH_URL}/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Skip env validation during Docker/CI builds
# SKIP_ENV_VALIDATION=1
